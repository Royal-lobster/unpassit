{
  "name": "unpassit",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "bin": {
    "unpassit": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/cli.ts --format esm --watch",
    "test": "npx tsx --test src/**/*.test.ts",
    "test:e2e": "npm run build && npx tsx --test test/**/*.test.ts",
    "test:all": "npm run test && npm run test:e2e",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "keywords": [
    "cli",
    "password",
    "decrypt",
    "pdf",
    "office",
    "zip",
    "rar",
    "7z",
    "unlock"
  ],
  "author": "srujangurram",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srujangurram/unpassit.git"
  },
  "dependencies": {
    "7zip-min": "^3.0.1",
    "archiver": "^7.0.1",
    "commander": "^14.0.3",
    "node-qpdf2": "^6.0.0",
    "node-unrar-js": "^2.0.2",
    "officecrypto-tool": "^0.0.19",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
